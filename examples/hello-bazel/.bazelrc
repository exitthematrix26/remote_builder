# ── Local build (default) ────────────────────────────────────────────────────
# Plain `bazel build //...` uses this config — no flags needed.

# ── Remote build via RBE ─────────────────────────────────────────────────────
# Usage: bazel build --config=rbe //...
#
# Prerequisites:
#   kubectl port-forward svc/bb-scheduler 8981:8981 -n rbe-system
#
# What each flag does:
#   --remote_executor         gRPC endpoint of the scheduler (Bazel's entry point)
#   --remote_cache            Same endpoint — bb-scheduler proxies AC/CAS reads
#   --remote_timeout          Seconds to wait for a single RPC call
#   --jobs                    How many parallel actions to submit; match worker concurrency
#   --build_event_text_file   Human-readable BEP log written locally (great for debugging)
#
# Platform constraints:
#   --platforms               Tells Bazel what platform to build FOR (the target)
#   --extra_execution_platforms  Platforms the remote workers can execute ON
#   The scheduler matches action platform properties to worker advertisements.
#   Our workers advertise OSFamily=linux,ISA=amd64 (set in values.yaml).
#
build:rbe --remote_executor=grpc://localhost:8981
build:rbe --remote_cache=grpc://localhost:8980
build:rbe --remote_timeout=120
build:rbe --jobs=4
build:rbe --build_event_text_file=/tmp/bep.txt

# Two-endpoint topology:
#   --remote_executor → bb-scheduler:8981  (execution capabilities, action routing)
#   --remote_cache    → bb-storage:8980    (cache capabilities + CAS/AC storage)
#
# Port-forwards required (both must be running):
#   kubectl port-forward svc/bb-scheduler 8981:8981 -n rbe-system &
#   kubectl port-forward svc/bb-storage   8980:8980 -n rbe-system &
#
# Bazel 9 queries GetCapabilities on BOTH endpoints separately:
#   - executor: gets ExecutionCapabilities (SHA256 execEnabled)
#   - cache:    gets CacheCapabilities (SHA256 digest functions)  ← bb-storage provides this
# Without the cache endpoint, Bazel gets empty CacheCapabilities and aborts.
# Explicit empty instance name — must match on both scheduler and storage sides
build:rbe --remote_instance_name=

# Execution platform: //:rbe_platform defines exec_properties {ISA=amd64, OSFamily=linux}
# which Bazel includes as REAPI platform properties in Execute requests.
# Workers register with the same properties — the scheduler uses exact matching.
# --extra_execution_platforms makes this platform available during exec platform resolution.
build:rbe --extra_execution_platforms=//:rbe_platform

# ── Verbose remote (debug) ───────────────────────────────────────────────────
# Usage: bazel build --config=rbe-verbose //...
# Adds gRPC-level logging — shows exactly which actions go remote vs local.
build:rbe-verbose --config=rbe
build:rbe-verbose --execution_log_binary_file=/tmp/exec.log
build:rbe-verbose --verbose_failures
build:rbe-verbose --subcommands=pretty_print
