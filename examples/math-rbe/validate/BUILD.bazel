# validate/BUILD.bazel
#
# Exposes validate_test.py and requirements.txt as targets.
# The actual py_test targets are generated by math_pipeline() in BUILD.bazel —
# they reference //validate:validate_test.py as srcs and main.
#
# requirements.txt is referenced by pip.parse() in MODULE.bazel:
#   pip.parse(requirements_lock = "//validate:requirements.txt")
# Bazel reads it at module load time and creates @math_rbe_pip//:pandas etc.

exports_files(
    ["validate_test.py", "requirements.txt"],
    visibility = ["//visibility:public"],
)
